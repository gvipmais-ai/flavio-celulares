generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  name               String
  email              String     @unique
  passwordHash       String
  role               String     @default("OPERADOR_CAIXA")
  isActive           Boolean    @default(true)
  mustChangePassword Boolean    @default(true)
  loginAttempts      Int        @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  createdProducts    Product[]           @relation("ProductCreatedBy")
  inventoryMovements InventoryMovement[]
  createdEntries     PurchaseEntry[]     @relation("PurchaseEntryCreatedBy")
  confirmedEntries   PurchaseEntry[]     @relation("PurchaseEntryConfirmedBy")
  canceledEntries    PurchaseEntry[]     @relation("PurchaseEntryCanceledBy")
  createdReservations StockReservation[] @relation("ReservationCreatedBy")
  cashSessions       CashSession[]
  cashMovements      CashMovement[]
  sales              Sale[]              @relation("SaleOperator")
  canceledSales      Sale[]              @relation("SaleCanceledBy")
  assignedOrders     ServiceOrder[]      @relation("ServiceOrderTechnician")
  createdOrders      ServiceOrder[]      @relation("ServiceOrderCreatedBy")
  statusHistories    ServiceOrderStatusHistory[]
  createdQuotes      Quote[]             @relation("QuoteCreatedBy")
  auditLogs          AuditLog[]

  @@map("users")
}

model StoreSettings {
  id                     String   @id @default("singleton")
  name                   String   @default("Flavio Celulares")
  tradeName              String?
  taxId                  String?
  address                String?
  city                   String?
  state                  String?
  zipCode                String?
  phone                  String?
  email                  String?
  logoUrl                String?
  receiptFooterText      String?  @default("Obrigado pela preferência! Garantia legal de 90 dias conforme CDC.")
  serviceOrderTerms      String?  @default("Aparelhos não retirados em até 90 dias após a conclusão serão vendidos para custeio do reparo.")
  defaultQuoteValidDays  Int      @default(7)
  defaultMinStock        Int      @default(3)
  maxOperatorDiscountPct Decimal  @default(5.0)
  allowNegativeStock     Boolean  @default(false)
  showWarrantyOnReceipt  Boolean  @default(true)
  showCostToOperator     Boolean  @default(false)
  saleSequence           Int      @default(1000)
  serviceOrderSequence   Int      @default(5000)
  updatedAt              DateTime @updatedAt

  @@map("store_settings")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Brand {
  id                    String    @id @default(cuid())
  name                  String    @unique
  defaultWarrantyMonths Int       @default(0)
  description           String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  products              Product[]
  deviceModels          DeviceModel[]

  @@map("brands")
}

model Supplier {
  id          String          @id @default(cuid())
  name        String
  tradeName   String?
  taxId       String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  notes       String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  products    Product[]
  purchaseEntries PurchaseEntry[]

  @@map("suppliers")
}

model DeviceModel {
  id          String    @id @default(cuid())
  brandId     String
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  brand       Brand                  @relation(fields: [brandId], references: [id])
  compatibilities ProductCompatibility[]
  serviceOrders   ServiceOrder[]

  @@unique([brandId, name])
  @@map("device_models")
}

model Product {
  id             String         @id @default(cuid())
  code           String         @unique
  barcode        String?        @unique
  name           String
  description    String?
  productType    String
  partType       String?
  costPrice      Decimal        @default(0)
  salePrice      Decimal
  stockOnHand    Int            @default(0)
  stockReserved  Int            @default(0)
  minimumStock   Int            @default(3)
  warrantyMonths Int            @default(3)
  unit           String         @default("UN")
  location       String?
  color          String?
  model          String?
  imageUrl       String?
  notes          String?
  approvalStatus String         @default("APROVADO")
  isActive       Boolean        @default(true)
  categoryId     String
  brandId        String
  supplierId     String?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  category          Category               @relation(fields: [categoryId], references: [id])
  brand             Brand                  @relation(fields: [brandId], references: [id])
  supplier          Supplier?              @relation(fields: [supplierId], references: [id])
  createdBy         User                   @relation("ProductCreatedBy", fields: [createdById], references: [id])
  compatibilities   ProductCompatibility[]
  inventoryMovements InventoryMovement[]
  purchaseEntryItems PurchaseEntryItem[]
  stockReservations StockReservation[]
  saleItems         SaleItem[]
  quoteItems        QuoteItem[]

  @@map("products")
}

model ProductCompatibility {
  id            String   @id @default(cuid())
  productId     String
  deviceModelId String
  createdAt     DateTime @default(now())

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  deviceModel DeviceModel @relation(fields: [deviceModelId], references: [id], onDelete: Cascade)

  @@unique([productId, deviceModelId])
  @@map("product_compatibilities")
}

model InventoryMovement {
  id              String            @id @default(cuid())
  productId       String
  quantity        Int
  direction       String
  reason          String
  previousBalance Int
  resultingBalance Int
  sourceType      String?
  sourceId        String?
  notes           String?
  userId          String
  createdAt       DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("inventory_movements")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  cpf       String?  @unique
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales         Sale[]
  serviceOrders ServiceOrder[]

  @@map("customers")
}

model PurchaseEntry {
  id                 String              @id @default(cuid())
  supplierId         String
  invoiceNumber      String
  invoiceSeries      String?
  accessKey          String?
  issueDate          DateTime
  entryDate          DateTime
  totalAmount        Decimal
  notes              String?
  status             String              @default("RASCUNHO")
  createdById        String
  confirmedById      String?
  confirmedAt        DateTime?
  canceledById       String?
  canceledAt         DateTime?
  cancellationReason String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  createdBy   User                @relation("PurchaseEntryCreatedBy", fields: [createdById], references: [id])
  confirmedBy User?               @relation("PurchaseEntryConfirmedBy", fields: [confirmedById], references: [id])
  canceledBy  User?               @relation("PurchaseEntryCanceledBy", fields: [canceledById], references: [id])
  items       PurchaseEntryItem[]

  @@unique([supplierId, invoiceNumber, invoiceSeries])
  @@map("purchase_entries")
}

model PurchaseEntryItem {
  id              String   @id @default(cuid())
  purchaseEntryId String
  productId       String
  quantity        Int
  unitCost        Decimal
  discount        Decimal  @default(0)
  subtotal        Decimal

  purchaseEntry PurchaseEntry @relation(fields: [purchaseEntryId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_entry_items")
}

model CashSession {
  id             String            @id @default(cuid())
  operatorId     String
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  openingAmount  Decimal
  expectedAmount Decimal?
  informedAmount Decimal?
  difference     Decimal?
  status         String            @default("ABERTA")
  notes          String?

  operator      User           @relation(fields: [operatorId], references: [id])
  cashMovements CashMovement[]
  sales         Sale[]

  @@map("cash_sessions")
}

model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  type          String
  amount        Decimal
  reason        String?
  sourceType    String?
  sourceId      String?
  userId        String
  createdAt     DateTime         @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@map("cash_movements")
}

model Sale {
  id                   String     @id @default(cuid())
  sequentialNumber     Int        @unique
  clientTransactionId  String     @unique
  customerId           String?
  customerNameSnapshot String
  customerCpfSnapshot  String?
  grossAmount          Decimal
  discountAmount       Decimal    @default(0)
  totalAmount          Decimal
  notes                String?
  status               String     @default("CONCLUIDA")
  operatorId           String
  cashSessionId        String
  canceledById         String?
  canceledAt           DateTime?
  cancellationReason   String?
  createdAt            DateTime   @default(now())

  customer    Customer?     @relation(fields: [customerId], references: [id])
  operator    User          @relation("SaleOperator", fields: [operatorId], references: [id])
  cashSession CashSession   @relation(fields: [cashSessionId], references: [id])
  canceledBy  User?         @relation("SaleCanceledBy", fields: [canceledById], references: [id])
  items       SaleItem[]
  payments    SalePayment[]

  @@map("sales")
}

model SaleItem {
  id                     String  @id @default(cuid())
  saleId                 String
  productId              String
  productCodeSnapshot    String
  productNameSnapshot    String
  quantity               Int
  costPriceSnapshot      Decimal
  unitPrice              Decimal
  discount               Decimal @default(0)
  subtotal               Decimal
  warrantyMonthsSnapshot Int     @default(3)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String
  paymentMethod String
  amount        Decimal
  createdAt     DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

model ServiceOrder {
  id                    String             @id @default(cuid())
  sequentialNumber      Int                @unique
  customerId            String
  deviceModelId         String?
  deviceBrandSnapshot   String
  deviceModelSnapshot   String
  imei                  String?
  color                 String?
  accessoriesReceived   String?
  reportedIssue         String
  visualCondition       String?
  observations          String?
  technicianId          String?
  createdById           String
  status                String             @default("RECEBIDO")
  receivedAt            DateTime           @default(now())
  estimatedCompletionAt DateTime?
  completedAt           DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  customer       Customer                    @relation(fields: [customerId], references: [id])
  deviceModel    DeviceModel?                @relation(fields: [deviceModelId], references: [id])
  technician     User?                       @relation("ServiceOrderTechnician", fields: [technicianId], references: [id])
  createdBy      User                        @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id])
  checklistItems ServiceChecklistItem[]
  statusHistory  ServiceOrderStatusHistory[]
  quotes         Quote[]
  reservations   StockReservation[]

  @@map("service_orders")
}

model ServiceChecklistItem {
  id                  String          @id @default(cuid())
  serviceOrderId      String
  descriptionSnapshot String
  result              String          @default("NAO_TESTADO")
  notes               String?
  displayOrder        Int             @default(0)
  suggestedPartType   String?

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@map("service_checklist_items")
}

model ServiceOrderStatusHistory {
  id             String             @id @default(cuid())
  serviceOrderId String
  previousStatus String?
  newStatus      String
  notes          String?
  userId         String
  createdAt      DateTime           @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@map("service_order_status_history")
}

model Quote {
  id             String      @id @default(cuid())
  serviceOrderId String
  version        Int         @default(1)
  diagnosis      String?
  laborAmount    Decimal     @default(0)
  discountAmount Decimal     @default(0)
  partsAmount    Decimal     @default(0)
  totalAmount    Decimal
  validUntil     DateTime?
  estimatedDays  Int?
  notes          String?
  status         String      @default("RASCUNHO")
  createdById    String
  approvedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  serviceOrder ServiceOrder       @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User               @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  items        QuoteItem[]
  reservations StockReservation[]

  @@map("quotes")
}

model QuoteItem {
  id                  String        @id @default(cuid())
  quoteId             String
  itemType            String
  productId           String?
  descriptionSnapshot String
  quantity            Int           @default(1)
  unitPrice           Decimal
  subtotal            Decimal

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

model StockReservation {
  id             String            @id @default(cuid())
  serviceOrderId String
  quoteId        String
  productId      String
  quantity       Int
  status         String            @default("ATIVA")
  createdById    String
  consumedAt     DateTime?
  releasedAt     DateTime?
  createdAt      DateTime          @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  quote        Quote        @relation(fields: [quoteId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  createdBy    User         @relation("ReservationCreatedBy", fields: [createdById], references: [id])

  @@map("stock_reservations")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  description String
  metadata    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ChecklistTemplateItem {
  id                String    @id @default(cuid())
  description       String
  displayOrder      Int       @default(0)
  suggestedPartType String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  @@map("checklist_template_items")
}
